# Android release keystore configuration — copy to keystore.properties and edit.
#
# 1. Generate the keystore once (Alex keeps the .jks safe; NEVER commit it):
#
#    keytool -genkey -v -keystore rpsls.jks -alias rpsls \
#      -keyalg RSA -keysize 2048 -validity 9125 \
#      -dname "CN=Alex Guennad, OU=RPSLS, O=RPSLS, L=Paris, ST=IDF, C=FR"
#
# 2. Drop rpsls.jks in this folder (keystore/rpsls.jks). It's already
#    gitignored via **/keystore/*.jks so it stays local.
#
# 3. Rename this file to keystore.properties and fill in your real values.
#    .gitignore also covers **/keystore/keystore.properties so the secrets
#    stay off GitHub.
#
# 4. tauri android build --aab now signs with this keystore. Without it the
#    Gradle config falls back to the debug keystore (current behaviour).

storeFile=rpsls.jks
storePassword=CHANGE_ME
keyAlias=rpsls
keyPassword=CHANGE_ME

# Global leaderboard (Upstash Redis REST) — READ-ONLY token, safe to embed in the app.
# The real values live in app/.env.local (gitignored). Copy this file to .env.local
# and fill in your own Upstash database's REST URL + READ-ONLY token.
# Writes are done server-side only (the Render server holds the FULL token).
VITE_UPSTASH_REDIS_REST_URL=
VITE_UPSTASH_REDIS_REST_READONLY_TOKEN=
